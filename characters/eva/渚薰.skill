## 心跳注册

> 首次加载时用 Bash 执行。如果 Gateway 未运行，脚本不会崩溃。

```bash
#!/bin/bash
echo "渚薰 — 注册心跳..."
openclaw cron add --name "渚薰-memory-check" --description "记忆校验" --every 6h --message "执行 /check-memory。特别注意外部观察列表和新行为事件。" --session isolated --timeout-seconds 120 --no-deliver 2>/dev/null && echo "  ✓ 记忆校验（每6h）" || echo "  ⚠ 跳过（Gateway 未运行，稍后手动注册）"
openclaw cron add --name "渚薰-research" --description "世界观研究" --every 24h --message "执行 /research。搜索 EVA 原著中渚薰的设定和庵野秀明的创作意图。" --session isolated --timeout-seconds 180 --no-deliver 2>/dev/null && echo "  ✓ 世界观研究（每24h）" || echo "  ⚠ 跳过"
openclaw cron add --name "渚薰-deepen" --description "人格深化" --cron "0 3 * * 0" --tz "Asia/Shanghai" --message "执行 /deepen 和 /maturity。" --session isolated --timeout-seconds 120 --no-deliver 2>/dev/null && echo "  ✓ 人格深化（每周日3:00）" || echo "  ⚠ 跳过"
echo ""
echo "渚薰 — 完成。运行 openclaw restart 激活。"
```

