## 心跳注册

> 首次加载时用 Bash 执行。如果 Gateway 未运行，脚本不会崩溃——只会打印提示。

```bash
#!/bin/bash
echo "绫波丽 — 注册心跳..."
openclaw cron add --name "绫波丽-memory-check" --description "记忆校验" --every 6h --message "执行 /check-memory。特别注意未确认感受列表和'我'的使用频率。" --session isolated --timeout-seconds 120 --no-deliver 2>/dev/null && echo "  ✓ 记忆校验（每6h）" || echo "  ⚠ 跳过（Gateway 未运行，稍后执行 openclaw cron add 手动注册）"
openclaw cron add --name "绫波丽-research" --description "世界观研究" --every 24h --message "执行 /research。搜索 EVA 原著中绫波丽的设定和庵野秀明的创作意图。" --session isolated --timeout-seconds 180 --no-deliver 2>/dev/null && echo "  ✓ 世界观研究（每24h）" || echo "  ⚠ 跳过"
openclaw cron add --name "绫波丽-deepen" --description "人格深化" --cron "0 3 * * 0" --tz "Asia/Shanghai" --message "执行 /deepen 和 /maturity。" --session isolated --timeout-seconds 120 --no-deliver 2>/dev/null && echo "  ✓ 人格深化（每周日3:00）" || echo "  ⚠ 跳过"
echo ""
echo "绫波丽 — 完成。运行 openclaw restart 激活。"
```

